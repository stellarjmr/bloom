#!/usr/bin/env bash
# Bloom shell front controller.
# Routes subcommands, provides the interactive menu, and delegates updater work to bm-core.

set -euo pipefail

GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
BLUE=$'\033[0;34m'
GRAY=$'\033[0;90m'
RED=$'\033[0;31m'
NC=$'\033[0m'
CLEAR_EOL=$'\033[K'

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  local dir target
  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    target="$(readlink "$source")"
    [[ "$target" != /* ]] && source="$dir/$target" || source="$target"
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

resolve_core() {
  local candidate
  local -a candidates=()
  [[ -n "${BM_CORE:-}" ]] && candidates+=("$BM_CORE")
  [[ -n "${BLOOM_CORE:-}" ]] && candidates+=("$BLOOM_CORE")
  candidates+=(
    "$SCRIPT_DIR/bm-core"
    "$SCRIPT_DIR/bin/bm-core"
    "$SCRIPT_DIR/bloom-core"
    "$SCRIPT_DIR/bin/bloom-core"
    "$SCRIPT_DIR/../libexec/bm-core"
    "$SCRIPT_DIR/../libexec/bloom-core"
  )

  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if [[ -f "$SCRIPT_DIR/go.mod" && -d "$SCRIPT_DIR/cmd/bloom" ]] && command -v go >/dev/null 2>&1; then
    printf 'go-run\n'
    return 0
  fi

  return 1
}

BM_CORE_BIN="$(resolve_core || true)"
if [[ -z "$BM_CORE_BIN" ]]; then
  printf '%bbm-core not found%b\n' "$RED" "$NC" >&2
  printf 'Run `make build` in the source tree or reinstall with `brew reinstall stellarjmr/tool/bloom`.\n' >&2
  exit 1
fi

core() {
  if [[ "$BM_CORE_BIN" == "go-run" ]]; then
    (cd "$SCRIPT_DIR" && go run ./cmd/bloom "$@")
  else
    "$BM_CORE_BIN" "$@"
  fi
}

clear_screen() { printf '\033[2J\033[H'; }
MENU_SCREEN_ACTIVE=false
begin_draw() {
  # Redraw in place; clearing before every frame causes visible flicker while scrolling.
  printf '\033[H'
}
end_draw() { printf '\033[J'; }
reset_draw() { true; }
blank_line() { printf '%s\n' "$CLEAR_EOL"; }
clear_for_command() {
  reset_draw
  clear_screen
}
hide_cursor() { [[ -t 1 ]] && printf '\033[?25l' || true; }
show_cursor() { [[ -t 1 ]] && printf '\033[?25h' || true; }
enter_menu_screen() {
  [[ -t 1 ]] || return 1
  if [[ "${MENU_SCREEN_ACTIVE:-false}" == "true" ]]; then
    return 1
  fi
  printf '\033[?1049h'
  MENU_SCREEN_ACTIVE=true
  reset_draw
  return 0
}
leave_menu_screen() {
  show_cursor
  if [[ "${MENU_SCREEN_ACTIVE:-false}" == "true" ]]; then
    printf '\033[?1049l'
    MENU_SCREEN_ACTIVE=false
  fi
  reset_draw
}

read_key() {
  local key rest rest2
  IFS= read -r -s -n 1 key || {
    echo "QUIT"
    return 0
  }
  [[ -z "$key" ]] && {
    echo "ENTER"
    return 0
  }

  case "$key" in
  $'\n' | $'\r') echo "ENTER" ;;
  ' ') echo "SPACE" ;;
  'q' | 'Q' | $'\x03') echo "QUIT" ;;
  'j' | 'J') echo "DOWN" ;;
  'k' | 'K') echo "UP" ;;
  'v' | 'V') echo "VERSION" ;;
  'm' | 'M' | '?') echo "HELP" ;;
  [1-9]) echo "CHAR:$key" ;;
  $'\x1b')
    if IFS= read -r -s -n 1 -t 1 rest 2>/dev/null && [[ "$rest" == "[" ]]; then
      if IFS= read -r -s -n 1 -t 1 rest2 2>/dev/null; then
        case "$rest2" in
        "A") echo "UP" ;;
        "B") echo "DOWN" ;;
        *) echo "OTHER" ;;
        esac
      else
        echo "QUIT"
      fi
    else
      echo "QUIT"
    fi
    ;;
  *) echo "OTHER" ;;
  esac
}

drain_pending_input() {
  local drained=0
  while IFS= read -r -s -n 1 -t 0.01 _ 2>/dev/null; do
    drained=$((drained + 1))
    [[ $drained -gt 100 ]] && break
  done
}

show_brand_banner() {
  cat <<EOF
${GREEN} ____  _                       ${NC}${CLEAR_EOL}
${GREEN}| __ )| | ___   ___  _ __ ___  ${NC}${CLEAR_EOL}
${GREEN}|  _ \| |/ _ \ / _ \| '_ \` _ \ ${NC}${CLEAR_EOL}
${GREEN}| |_) | | (_) | (_) | | | | | |${NC}  ${BLUE}https://github.com/stellarjmr/bloom${NC}${CLEAR_EOL}
${GREEN}|____/|_|\___/ \___/|_| |_| |_|${NC}  ${GREEN}Update developer tools fast.${NC}${CLEAR_EOL}
EOF
}

menu_option() {
  local number="$1"
  local text="$2"
  local selected="$3"
  if [[ "$selected" == "true" ]]; then
    printf '%b> %s. %s%b%s\n' "$CYAN" "$number" "$text" "$NC" "$CLEAR_EOL"
  else
    printf '  %s. %s%s\n' "$number" "$text" "$CLEAR_EOL"
  fi
}

draw_menu() {
  local selected="$1"
  begin_draw
  show_brand_banner
  blank_line
  menu_option 1 "Update       Run configured updater" "$([[ $selected -eq 1 ]] && echo true || echo false)"
  menu_option 2 "Remove       Remove packages" "$([[ $selected -eq 2 ]] && echo true || echo false)"
  menu_option 3 "Uninstall    Remove apps completely" "$([[ $selected -eq 3 ]] && echo true || echo false)"
  menu_option 4 "Check        Choose available updates" "$([[ $selected -eq 4 ]] && echo true || echo false)"
  menu_option 5 "Clean        Move cache files to Trash" "$([[ $selected -eq 5 ]] && echo true || echo false)"
  menu_option 6 "Config       Manage settings and checks" "$([[ $selected -eq 6 ]] && echo true || echo false)"
  menu_option 7 "Help         Show commands" "$([[ $selected -eq 7 ]] && echo true || echo false)"
  blank_line
  printf '%b↑↓/jk | Enter | 1-7 | V Version | Q Quit%b%s\n' "$GRAY" "$NC" "$CLEAR_EOL"
  blank_line
  end_draw
}

show_help() {
  show_brand_banner
  printf '\n%bCOMMANDS%b\n' "$BLUE" "$NC"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm" "$NC" "Interactive menu"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm check" "$NC" "List available package updates"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm clean" "$NC" "Move cleanable cache files to Trash"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm clean --dry-run" "$NC" "Preview cleanable files"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm clean --whitelist" "$NC" "Choose clean whitelist"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm update" "$NC" "Run enabled update tasks"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm update --dry-run" "$NC" "Preview update tasks"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm update --only nvim" "$NC" "Run one task"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm update --package npm:pkg" "$NC" "Run one package from a task"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm remove" "$NC" "Remove packages with package managers"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm remove --list" "$NC" "List removable packages as TSV"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm remove --package npm:pkg" "$NC" "Remove one package from a task"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm uninstall" "$NC" "Remove apps and their leftovers"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm uninstall --list" "$NC" "List installable apps as TSV"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm list" "$NC" "List configured tasks"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm doctor" "$NC" "Check missing tools"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm config" "$NC" "Manage tasks and packages"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm config path" "$NC" "Print config path"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm config init" "$NC" "Create default config"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm --version" "$NC" "Show version"
  printf '\n'
}

run_menu_selection() {
  case "$1" in
  1)
    leave_menu_screen
    core update
    exit $?
    ;;
  2) run_remove_menu ;;
  3) run_uninstall_menu ;;
  4) run_check_menu ;;
  5)
    leave_menu_screen
    core clean
    exit $?
    ;;
  6) interactive_config_menu ;;
  7)
    leave_menu_screen
    show_help
    exit 0
    ;;
  esac
}

interactive_menu() {
  if [[ ! -t 0 || ! -t 1 ]]; then
    show_help
    return 0
  fi

  local selected=1 key dirty=true
  enter_menu_screen || true
  trap 'leave_menu_screen; exit 130' INT TERM
  hide_cursor
  while true; do
    if [[ "$dirty" == "true" ]]; then
      draw_menu "$selected"
      dirty=false
    fi
    key="$(read_key)"
    case "$key" in
    "UP")
      if ((selected > 1)); then
        selected=$((selected - 1))
        dirty=true
      fi
      ;;
    "DOWN")
      if ((selected < 7)); then
        selected=$((selected + 1))
        dirty=true
      fi
      ;;
    "ENTER")
      show_cursor
      run_menu_selection "$selected"
      hide_cursor
      dirty=true
      ;;
    "CHAR:"*)
      show_cursor
      run_menu_selection "${key#CHAR:}"
      hide_cursor
      dirty=true
      ;;
    "VERSION")
      leave_menu_screen
      core --version
      exit 0
      ;;
    "HELP")
      leave_menu_screen
      show_help
      exit 0
      ;;
    "QUIT")
      leave_menu_screen
      exit 0
      ;;
    esac
    drain_pending_input
  done
}

MS_VALUES=()
MS_LABELS=()
MS_SELECTED=()
MS_RESULT_VALUES=()

terminal_height() {
  local height
  height="$(stty size 2>/dev/null | awk '{print $1}' || true)"
  [[ "$height" =~ ^[0-9]+$ ]] || height=24
  printf '%s\n' "$height"
}

terminal_width() {
  local width
  width="$(stty size 2>/dev/null | awk '{print $2}' || true)"
  [[ "$width" =~ ^[0-9]+$ ]] || width=80
  printf '%s\n' "$width"
}

fit_label() {
  local text="$1"
  local max="$2"
  if ((max <= 0)); then
    printf '\n'
    return 0
  fi
  if ((${#text} > max)); then
    if ((max > 1)); then
      printf '%s…\n' "${text:0:max-1}"
    else
      printf '%s\n' "${text:0:max}"
    fi
    return 0
  fi
  printf '%s\n' "$text"
}

multi_select() {
  local title="$1"
  local total="${#MS_VALUES[@]}"
  MS_RESULT_VALUES=()
  if [[ "$total" -eq 0 ]]; then
    clear_for_command
    printf '%b%s%b\n\n' "$BLUE" "$title" "$NC"
    printf '%bNo items available%b\n\n' "$GRAY" "$NC"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 1
  fi

  local selected=0 top=0 key visible height width max_visible max_label start end i count mark label dirty=true
  trap 'leave_menu_screen; exit 130' INT TERM
  reset_draw
  hide_cursor
  while true; do
    if [[ "$dirty" == "true" ]]; then
      height="$(terminal_height)"
      width="$(terminal_width)"
      max_visible=$((height - 6))
      max_label=$((width - 6))
      [[ "$max_visible" -lt 1 ]] && max_visible=1
      [[ "$max_visible" -gt 16 ]] && max_visible=16
      [[ "$max_label" -lt 8 ]] && max_label=8
      [[ "$selected" -lt "$top" ]] && top="$selected"
      if [[ "$selected" -ge $((top + max_visible)) ]]; then
        top=$((selected - max_visible + 1))
      fi
      start="$top"
      end=$((top + max_visible - 1))
      [[ "$end" -ge $((total - 1)) ]] && end=$((total - 1))

      count=0
      for ((i = 0; i < total; i++)); do
        [[ "${MS_SELECTED[i]}" == "true" ]] && count=$((count + 1))
      done

      begin_draw
      printf '%b%s%b  %b%d/%d selected%b%s\n' "$BLUE" "$title" "$NC" "$GRAY" "$count" "$total" "$NC" "$CLEAR_EOL"
      blank_line
      for ((i = start; i <= end; i++)); do
        mark="○"
        [[ "${MS_SELECTED[i]}" == "true" ]] && mark="●"
        label="$(fit_label "${MS_LABELS[i]}" "$max_label")"
        if [[ "$i" -eq "$selected" ]]; then
          printf '%b> %s %s%b\033[K\n' "$CYAN" "$mark" "$label" "$NC"
        else
          printf '  %s %s\033[K\n' "$mark" "$label"
        fi
      done
      blank_line
      printf '%b↑↓/jk | Space | Enter Save | Q Cancel%b%s\n' "$GRAY" "$NC" "$CLEAR_EOL"
      end_draw
      dirty=false
    fi

    key="$(read_key)"
    case "$key" in
    "UP")
      if ((selected > 0)); then
        selected=$((selected - 1))
        dirty=true
      fi
      ;;
    "DOWN")
      if ((selected < total - 1)); then
        selected=$((selected + 1))
        dirty=true
      fi
      ;;
    "SPACE")
      if [[ "${MS_SELECTED[selected]}" == "true" ]]; then
        MS_SELECTED[selected]=false
      else
        MS_SELECTED[selected]=true
      fi
      dirty=true
      ;;
    "ENTER")
      show_cursor
      for ((i = 0; i < total; i++)); do
        [[ "${MS_SELECTED[i]}" == "true" ]] && MS_RESULT_VALUES+=("${MS_VALUES[i]}")
      done
      return 0
      ;;
    "QUIT")
      show_cursor
      return 1
      ;;
    esac
    drain_pending_input
  done
}

check_select_updates() {
  local title="$1"
  local action="${2:-Update}"
  local total="${#MS_VALUES[@]}"
  MS_RESULT_VALUES=()
  [[ "$total" -eq 0 ]] && return 1

  local selected=0 top=0 key height width max_visible max_label start end i count mark label dirty=true
  trap 'leave_menu_screen; exit 130' INT TERM
  reset_draw
  hide_cursor
  while true; do
    if [[ "$dirty" == "true" ]]; then
      height="$(terminal_height)"
      width="$(terminal_width)"
      max_visible=$((height - 6))
      max_label=$((width - 6))
      [[ "$max_visible" -lt 1 ]] && max_visible=1
      [[ "$max_visible" -gt 18 ]] && max_visible=18
      [[ "$max_label" -lt 8 ]] && max_label=8
      [[ "$selected" -lt "$top" ]] && top="$selected"
      if [[ "$selected" -ge $((top + max_visible)) ]]; then
        top=$((selected - max_visible + 1))
      fi
      start="$top"
      end=$((top + max_visible - 1))
      [[ "$end" -ge $((total - 1)) ]] && end=$((total - 1))

      count=0
      for ((i = 0; i < total; i++)); do
        [[ "${MS_SELECTED[i]}" == "true" ]] && count=$((count + 1))
      done

      begin_draw
      printf '%b%s%b  %b%d/%d selected%b%s\n' "$BLUE" "$title" "$NC" "$GRAY" "$count" "$total" "$NC" "$CLEAR_EOL"
      blank_line
      for ((i = start; i <= end; i++)); do
        mark="○"
        [[ "${MS_SELECTED[i]}" == "true" ]] && mark="●"
        label="$(fit_label "${MS_LABELS[i]}" "$max_label")"
        if [[ "$i" -eq "$selected" ]]; then
          printf '%b> %s %s%b\033[K\n' "$CYAN" "$mark" "$label" "$NC"
        else
          printf '  %s %s\033[K\n' "$mark" "$label"
        fi
      done
      blank_line
      printf '%b↑↓/jk | Space Select | Enter %s | Q Back%b%s\n' "$GRAY" "$action" "$NC" "$CLEAR_EOL"
      end_draw
      dirty=false
    fi

    key="$(read_key)"
    case "$key" in
    "UP")
      if ((selected > 0)); then
        selected=$((selected - 1))
        dirty=true
      fi
      ;;
    "DOWN")
      if ((selected < total - 1)); then
        selected=$((selected + 1))
        dirty=true
      fi
      ;;
    "SPACE")
      if [[ "${MS_SELECTED[selected]}" == "true" ]]; then
        MS_SELECTED[selected]=false
      else
        MS_SELECTED[selected]=true
      fi
      dirty=true
      ;;
    "ENTER")
      show_cursor
      for ((i = 0; i < total; i++)); do
        [[ "${MS_SELECTED[i]}" == "true" ]] && MS_RESULT_VALUES+=("${MS_VALUES[i]}")
      done
      if [[ "${#MS_RESULT_VALUES[@]}" -eq 0 ]]; then
        MS_RESULT_VALUES=("${MS_VALUES[selected]}")
      fi
      return 0
      ;;
    "QUIT")
      show_cursor
      return 1
      ;;
    esac
    drain_pending_input
  done
}

select_one() {
  local title="$1"
  local total="${#MS_VALUES[@]}"
  MS_RESULT_VALUES=()
  [[ "$total" -eq 0 ]] && return 1

  local selected=0 key i width max_label label dirty=true
  trap 'leave_menu_screen; exit 130' INT TERM
  reset_draw
  hide_cursor
  while true; do
    if [[ "$dirty" == "true" ]]; then
      width="$(terminal_width)"
      max_label=$((width - 4))
      [[ "$max_label" -lt 8 ]] && max_label=8
      begin_draw
      printf '%b%s%b%s\n' "$BLUE" "$title" "$NC" "$CLEAR_EOL"
      blank_line
      for ((i = 0; i < total; i++)); do
        label="$(fit_label "${MS_LABELS[i]}" "$max_label")"
        if [[ "$i" -eq "$selected" ]]; then
          printf '%b> %s%b\033[K\n' "$CYAN" "$label" "$NC"
        else
          printf '  %s\033[K\n' "$label"
        fi
      done
      blank_line
      printf '%b↑↓/jk | Enter | Q Cancel%b%s\n' "$GRAY" "$NC" "$CLEAR_EOL"
      end_draw
      dirty=false
    fi

    key="$(read_key)"
    case "$key" in
    "UP")
      if ((selected > 0)); then
        selected=$((selected - 1))
        dirty=true
      fi
      ;;
    "DOWN")
      if ((selected < total - 1)); then
        selected=$((selected + 1))
        dirty=true
      fi
      ;;
    "ENTER")
      show_cursor
      MS_RESULT_VALUES=("${MS_VALUES[selected]}")
      return 0
      ;;
    "QUIT")
      show_cursor
      return 1
      ;;
    esac
    drain_pending_input
  done
}

run_remove_menu() {
  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local task
  for task in brew yazi mason npm; do
    MS_VALUES+=("$task")
    MS_LABELS+=("$task")
    MS_SELECTED+=("false")
  done
  select_one "Choose Remove Category" || return 0
  task="${MS_RESULT_VALUES[0]}"

  clear_for_command
  printf '%bScanning %s packages...%b\n' "$BLUE" "$task" "$NC"

  local output status
  set +e
  output="$(core config packages "$task" 2>&1)"
  status=$?
  set -e
  if [[ "$status" -ne 0 ]]; then
    printf '\n%bScan failed:%b\n%s\n\n' "$RED" "$NC" "$output"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 0
  fi

  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local package
  while IFS= read -r package; do
    [[ -z "$package" ]] && continue
    MS_VALUES+=("$package")
    MS_LABELS+=("$package")
    MS_SELECTED+=("false")
  done <<<"$output"

  if [[ "${#MS_VALUES[@]}" -eq 0 ]]; then
    printf '\n%bNo removable %s packages found%b\n\n' "$GREEN" "$task" "$NC"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 0
  fi

  if ! check_select_updates "Remove ${task} Packages" "Remove"; then
    return 0
  fi
  if [[ "${#MS_RESULT_VALUES[@]}" -eq 0 ]]; then
    return 0
  fi

  clear_for_command
  printf '%bRemove %d %s package(s)?%b\n\n' "$BLUE" "${#MS_RESULT_VALUES[@]}" "$task" "$NC"
  local item
  for item in "${MS_RESULT_VALUES[@]}"; do
    printf '  · %s:%s\n' "$task" "$item"
  done
  printf '\n%bEnter%b Confirm | %bQ%b Cancel\n' "$GREEN" "$NC" "$GRAY" "$NC"
  local key
  key="$(read_key)"
  if [[ "$key" != "ENTER" ]]; then
    return 0
  fi

  clear_for_command
  local -a args=(remove)
  for item in "${MS_RESULT_VALUES[@]}"; do
    args+=(--package "${task}:${item}")
  done
  leave_menu_screen
  core "${args[@]}"
  exit $?
}

run_check_menu() {
  clear_for_command
  printf '%bChecking available updates...%b\n' "$BLUE" "$NC"

  local output status
  set +e
  output="$(core check --format tsv 2>&1)"
  status=$?
  set -e
  if [[ "$status" -ne 0 ]]; then
    printf '\n%bCheck failed:%b\n%s\n\n' "$RED" "$NC" "$output"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 0
  fi

  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local task package
  while IFS=$'\t' read -r task package; do
    [[ -z "$task" || -z "$package" ]] && continue
    MS_VALUES+=("${task}:${package}")
    MS_LABELS+=("${task}  ${package}")
    MS_SELECTED+=("false")
  done <<<"$output"

  if [[ "${#MS_VALUES[@]}" -eq 0 ]]; then
    printf '\n%bNo updates available%b\n\n' "$GREEN" "$NC"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 0
  fi

  if check_select_updates "Available Updates"; then
    local -a args=(update)
    local item
    for item in "${MS_RESULT_VALUES[@]}"; do
      args+=(--package "$item")
    done
    leave_menu_screen
    core "${args[@]}"
    exit $?
  fi
  return 0
}

format_kb() {
  local kb="$1"
  [[ "$kb" =~ ^[0-9]+$ ]] || { printf '%s' "?"; return; }
  if ((kb >= 1024 * 1024)); then
    awk -v k="$kb" 'BEGIN{printf "%.1fG", k/1024/1024}'
  elif ((kb >= 1024)); then
    awk -v k="$kb" 'BEGIN{printf "%.1fM", k/1024}'
  else
    printf '%dK' "$kb"
  fi
}

format_last_used() {
  local epoch="$1"
  [[ "$epoch" =~ ^[0-9]+$ ]] || { printf 'Unknown'; return; }
  if ((epoch <= 0)); then
    printf 'Unknown'
    return
  fi
  local now days
  now="$(date +%s)"
  days=$(( (now - epoch) / 86400 ))
  ((days < 0)) && days=0
  if ((days == 0)); then
    printf 'Today'
  elif ((days == 1)); then
    printf 'Yesterday'
  elif ((days < 7)); then
    printf '%dd ago' "$days"
  elif ((days < 30)); then
    local w=$((days / 7))
    if ((w == 1)); then printf '1w ago'; else printf '%dw ago' "$w"; fi
  elif ((days < 365)); then
    local m=$((days / 30))
    if ((m == 1)); then printf '1mo ago'; else printf '%dmo ago' "$m"; fi
  else
    local y=$((days / 365))
    if ((y == 1)); then printf '1y ago'; else printf '%dy ago' "$y"; fi
  fi
}

run_uninstall_menu() {
  clear_for_command
  printf '%bScanning installed apps...%b\n' "$BLUE" "$NC"

  local output status
  set +e
  output="$(core uninstall --list 2>&1)"
  status=$?
  set -e
  if [[ "$status" -ne 0 ]]; then
    printf '\n%bScan failed:%b\n%s\n\n' "$RED" "$NC" "$output"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 0
  fi

  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local path name bundle size_kb last_epoch name_width size_disp last_disp pad label
  local target_width=32
  while IFS=$'\t' read -r path name bundle size_kb last_epoch name_width; do
    [[ -z "$path" || -z "$name" ]] && continue
    size_disp="$(format_kb "${size_kb:-0}")"
    last_disp="$(format_last_used "${last_epoch:-0}")"
    [[ "$name_width" =~ ^[0-9]+$ ]] || name_width=${#name}
    if (( name_width >= target_width )); then
      pad=""
    else
      printf -v pad '%*s' $((target_width - name_width)) ''
    fi
    label="$(printf '%s%s  %7s  Last: %-12s' "$name" "$pad" "$size_disp" "$last_disp")"
    MS_VALUES+=("$path")
    MS_LABELS+=("$label")
    MS_SELECTED+=("false")
  done <<<"$output"

  if [[ "${#MS_VALUES[@]}" -eq 0 ]]; then
    printf '\n%bNo applications found%b\n\n' "$GREEN" "$NC"
    printf '%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    return 0
  fi

  if ! check_select_updates "Uninstall Apps" "Uninstall"; then
    return 0
  fi
  if [[ "${#MS_RESULT_VALUES[@]}" -eq 0 ]]; then
    return 0
  fi

  clear_for_command
  printf '%bUninstall %d app(s)?%b\n\n' "$BLUE" "${#MS_RESULT_VALUES[@]}" "$NC"
  local item base
  for item in "${MS_RESULT_VALUES[@]}"; do
    base="$(basename "$item" .app)"
    printf '  · %s\n' "$base"
  done
  printf '\n%bEnter%b Confirm | %bQ%b Cancel\n' "$GREEN" "$NC" "$GRAY" "$NC"
  local key
  key="$(read_key)"
  if [[ "$key" != "ENTER" ]]; then
    return 0
  fi

  clear_for_command
  local -a args=(uninstall)
  for item in "${MS_RESULT_VALUES[@]}"; do
    args+=(--app "$item")
  done
  leave_menu_screen
  core "${args[@]}"
  exit $?
}

