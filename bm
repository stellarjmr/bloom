configure_tasks() {
  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local name enabled desc
  while IFS=$'\t' read -r name enabled desc; do
    [[ -z "$name" ]] && continue
    MS_VALUES+=("$name")
    MS_LABELS+=("$name  ${desc}")
    if [[ "$enabled" == "true" ]]; then
      MS_SELECTED+=("true")
    else
      MS_SELECTED+=("false")
    fi
  done < <(core config tasks)

  if multi_select "Select Update Tasks"; then
    core config set-tasks "${MS_RESULT_VALUES[@]}" >/dev/null
  fi
}

configure_packages() {
  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local task
  for task in brew cask yazi nvim mason npm; do
    MS_VALUES+=("$task")
    MS_LABELS+=("$task")
    MS_SELECTED+=("false")
  done
  select_one "Choose Task" || return 0
  task="${MS_RESULT_VALUES[0]}"

  local -a include=()
  local item found
  while IFS= read -r item; do
    [[ -n "$item" ]] && include+=("$item")
  done < <(core config include "$task")

  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  while IFS= read -r item; do
    [[ -z "$item" ]] && continue
    MS_VALUES+=("$item")
    MS_LABELS+=("$item")
    if [[ "${#include[@]}" -eq 0 ]]; then
      MS_SELECTED+=("true")
    else
      found=false
      local selected_item
      for selected_item in "${include[@]}"; do
        [[ "$selected_item" == "$item" ]] && found=true
      done
      if [[ "$found" == "true" ]]; then
        MS_SELECTED+=("true")
      else
        MS_SELECTED+=("false")
      fi
    fi
  done < <(core config packages "$task")

  if multi_select "Select ${task} Packages"; then
    if [[ "${#MS_RESULT_VALUES[@]}" -eq 0 ]]; then
      clear_for_command
      printf '%bNo packages selected.%b\n\n' "$BLUE" "$NC"
      printf 'Package filters were not changed. Disable the task from %bTasks%b if you want to skip it entirely.\n\n' "$GREEN" "$NC"
      printf '%bPress any key to return%b\n' "$GRAY" "$NC"
      read_key >/dev/null
    elif [[ "${#MS_RESULT_VALUES[@]}" -eq "${#MS_VALUES[@]}" ]]; then
      core config set-include "$task" >/dev/null
    else
      core config set-include "$task" "${MS_RESULT_VALUES[@]}" >/dev/null
    fi
  fi
}

configure_clean_whitelist() {
  local -a include=()
  local item found selected_item
  while IFS= read -r item; do
    [[ -n "$item" ]] && include+=("$item")
  done < <(core config clean-whitelist)

  MS_VALUES=()
  MS_LABELS=()
  MS_SELECTED=()
  local label pattern category
  while IFS=$'\t' read -r label pattern category; do
    [[ -z "$label" || -z "$pattern" ]] && continue
    MS_VALUES+=("$pattern")
    MS_LABELS+=("$label")
    found=false
    for selected_item in "${include[@]}"; do
      [[ "$selected_item" == "$pattern" ]] && found=true
    done
    if [[ "$found" == "true" ]]; then
      MS_SELECTED+=("true")
    else
      MS_SELECTED+=("false")
    fi
  done < <(core config clean-whitelist-items)

  if multi_select "Choose clean whitelist"; then
    core config set-clean-whitelist "${MS_RESULT_VALUES[@]}" >/dev/null
  fi
}

reset_config() {
  clear_for_command
  printf '%bReset Bloom config to defaults?%b\n\n' "$BLUE" "$NC"
  printf '%bEnter%b Reset | %bQ%b Cancel\n' "$GREEN" "$NC" "$GRAY" "$NC"
  local key
  key="$(read_key)"
  if [[ "$key" == "ENTER" ]]; then
    core config reset >/dev/null
  fi
}

run_config_selection() {
  case "$1" in
  1) configure_tasks ;;
  2) configure_packages ;;
  3) configure_clean_whitelist ;;
  4)
    leave_menu_screen
    exec "$0" list
    ;;
  5)
    leave_menu_screen
    exec "$0" doctor
    ;;
  6)
    clear_for_command
    core config path
    printf '\n%bPress any key to return%b\n' "$GRAY" "$NC"
    read_key >/dev/null
    ;;
  7) reset_config ;;
  8) return 1 ;;
  esac
  reset_draw
  return 0
}

interactive_config_menu() {
  if [[ ! -t 0 || ! -t 1 ]]; then
    core config
    return 0
  fi

  local selected=1 key dirty=true owns_screen=false
  if enter_menu_screen; then
    owns_screen=true
  fi
  trap 'leave_menu_screen; exit 130' INT TERM
  hide_cursor
  while true; do
    if [[ "$dirty" == "true" ]]; then
      draw_config_menu "$selected"
      dirty=false
    fi
    key="$(read_key)"
    case "$key" in
    "UP")
      if ((selected > 1)); then
        selected=$((selected - 1))
        dirty=true
      fi
      ;;
    "DOWN")
      if ((selected < 8)); then
        selected=$((selected + 1))
        dirty=true
      fi
      ;;
    "ENTER")
      show_cursor
      run_config_selection "$selected" || {
        [[ "$owns_screen" == "true" ]] && leave_menu_screen
        return 0
      }
      hide_cursor
      dirty=true
      ;;
    "CHAR:"*)
      show_cursor
      run_config_selection "${key#CHAR:}" || {
        [[ "$owns_screen" == "true" ]] && leave_menu_screen
        return 0
      }
      hide_cursor
      dirty=true
      ;;
    "QUIT")
      if [[ "$owns_screen" == "true" ]]; then
        leave_menu_screen
      else
        show_cursor
      fi
      return 0
      ;;
    esac
    drain_pending_input
  done
}

case "${1:-}" in
"")
  interactive_menu
  ;;
"help" | "--help" | "-h")
  show_help
  ;;
"version" | "--version" | "-v" | "-V")
  core --version
  ;;
"config")
  if [[ $# -eq 1 ]]; then
    interactive_config_menu
  else
    core "$@"
  fi
  ;;
"clean")
  if [[ "${2:-}" == "--whitelist" && "$#" -eq 2 && -t 0 && -t 1 ]]; then
    enter_menu_screen || true
    trap 'leave_menu_screen; exit 130' INT TERM
    configure_clean_whitelist
    leave_menu_screen
  else
    core "$@"
  fi
  ;;
"update" | "check" | "list" | "doctor" | "remove" | "uninstall")
  core "$@"
  ;;
*)
  printf '%bUnknown command:%b %s\n' "$RED" "$NC" "$1" >&2
  printf "Use 'bm --help' for usage information.\n" >&2
  exit 2
  ;;
esac
