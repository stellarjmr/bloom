#!/usr/bin/env bash
# Bloom shell front controller.
# Routes subcommands, provides the interactive menu, and delegates updater work to bloom-core.

set -euo pipefail

GREEN=$'\033[0;32m'
CYAN=$'\033[0;36m'
BLUE=$'\033[0;34m'
GRAY=$'\033[0;90m'
RED=$'\033[0;31m'
NC=$'\033[0m'

resolve_script_dir() {
  local source="${BASH_SOURCE[0]}"
  local dir target
  while [[ -L "$source" ]]; do
    dir="$(cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd)"
    target="$(readlink "$source")"
    [[ "$target" != /* ]] && source="$dir/$target" || source="$target"
  done
  cd -P "$(dirname "$source")" >/dev/null 2>&1 && pwd
}

SCRIPT_DIR="$(resolve_script_dir)"

resolve_core() {
  local candidate
  local -a candidates=()
  [[ -n "${BLOOM_CORE:-}" ]] && candidates+=("$BLOOM_CORE")
  candidates+=(
    "$SCRIPT_DIR/bloom-core"
    "$SCRIPT_DIR/bin/bloom-core"
    "$SCRIPT_DIR/../libexec/bloom-core"
  )

  for candidate in "${candidates[@]}"; do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  if [[ -f "$SCRIPT_DIR/go.mod" && -d "$SCRIPT_DIR/cmd/bloom" ]] && command -v go >/dev/null 2>&1; then
    printf 'go-run\n'
    return 0
  fi

  return 1
}

BLOOM_CORE_BIN="$(resolve_core || true)"
if [[ -z "$BLOOM_CORE_BIN" ]]; then
  printf '%bbloom-core not found%b\n' "$RED" "$NC" >&2
  printf 'Run `make build` in the source tree or reinstall with `brew reinstall stellarjmr/tool/bloom`.\n' >&2
  exit 1
fi

core() {
  if [[ "$BLOOM_CORE_BIN" == "go-run" ]]; then
    (cd "$SCRIPT_DIR" && go run ./cmd/bloom "$@")
  else
    "$BLOOM_CORE_BIN" "$@"
  fi
}

clear_screen() { printf '\033[2J\033[H'; }
hide_cursor() { [[ -t 1 ]] && printf '\033[?25l' || true; }
show_cursor() { [[ -t 1 ]] && printf '\033[?25h' || true; }

read_key() {
  local key rest rest2
  IFS= read -r -s -n 1 key || {
    echo "QUIT"
    return 0
  }
  [[ -z "$key" ]] && {
    echo "ENTER"
    return 0
  }

  case "$key" in
  $'\n' | $'\r') echo "ENTER" ;;
  'q' | 'Q' | $'\x03') echo "QUIT" ;;
  'j' | 'J') echo "DOWN" ;;
  'k' | 'K') echo "UP" ;;
  'v' | 'V') echo "VERSION" ;;
  'm' | 'M' | '?') echo "HELP" ;;
  [1-6]) echo "CHAR:$key" ;;
  $'\x1b')
    if IFS= read -r -s -n 1 -t 1 rest 2>/dev/null && [[ "$rest" == "[" ]]; then
      if IFS= read -r -s -n 1 -t 1 rest2 2>/dev/null; then
        case "$rest2" in
        "A") echo "UP" ;;
        "B") echo "DOWN" ;;
        *) echo "OTHER" ;;
        esac
      else
        echo "QUIT"
      fi
    else
      echo "QUIT"
    fi
    ;;
  *) echo "OTHER" ;;
  esac
}

drain_pending_input() {
  local drained=0
  while IFS= read -r -s -n 1 -t 0.01 _ 2>/dev/null; do
    drained=$((drained + 1))
    [[ $drained -gt 100 ]] && break
  done
}

show_brand_banner() {
  cat <<EOF
${GREEN} ____  _                       ${NC}
${GREEN}| __ )| | ___   ___  _ __ ___  ${NC}
${GREEN}|  _ \| |/ _ \ / _ \| '_ \` _ \ ${NC}
${GREEN}| |_) | | (_) | (_) | | | | | |${NC}  ${BLUE}https://github.com/stellarjmr/bloom${NC}
${GREEN}|____/|_|\___/ \___/|_| |_| |_|${NC}  ${GREEN}Update developer tools fast.${NC}
EOF
}

menu_option() {
  local number="$1"
  local text="$2"
  local selected="$3"
  if [[ "$selected" == "true" ]]; then
    printf '%b> %s. %s%b\n' "$CYAN" "$number" "$text" "$NC"
  else
    printf '  %s. %s\n' "$number" "$text"
  fi
}

draw_menu() {
  local selected="$1"
  clear_screen
  show_brand_banner
  printf '\n'
  menu_option 1 "Update       Run configured updater" "$([[ $selected -eq 1 ]] && echo true || echo false)"
  menu_option 2 "List         Show configured tasks" "$([[ $selected -eq 2 ]] && echo true || echo false)"
  menu_option 3 "Doctor       Check missing tools" "$([[ $selected -eq 3 ]] && echo true || echo false)"
  menu_option 4 "Config       Show config path" "$([[ $selected -eq 4 ]] && echo true || echo false)"
  menu_option 5 "Init Config  Create default config" "$([[ $selected -eq 5 ]] && echo true || echo false)"
  menu_option 6 "Help         Show commands" "$([[ $selected -eq 6 ]] && echo true || echo false)"
  printf '\n%b↑↓/jk | Enter | 1-6 | V Version | Q Quit%b\n\n' "$GRAY" "$NC"
}

show_help() {
  show_brand_banner
  printf '\n%bCOMMANDS%b\n' "$BLUE" "$NC"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm" "$NC" "Quick update, same as bloom update"
  printf '  %b%-28s%b %s\n' "$GREEN" "bm --dry-run" "$NC" "Preview update tasks"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom" "$NC" "Interactive menu"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom update" "$NC" "Run enabled update tasks"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom list" "$NC" "List configured tasks"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom doctor" "$NC" "Check missing tools"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom config path" "$NC" "Print config path"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom config init" "$NC" "Create default config"
  printf '  %b%-28s%b %s\n' "$GREEN" "bloom --version" "$NC" "Show version"
  printf '\n'
}

run_menu_selection() {
  case "$1" in
  1) exec "$0" update ;;
  2) exec "$0" list ;;
  3) exec "$0" doctor ;;
  4)
    clear_screen
    core config path
    exit 0
    ;;
  5) exec "$0" config init ;;
  6)
    clear_screen
    show_help
    exit 0
    ;;
  esac
}

interactive_menu() {
  if [[ ! -t 0 || ! -t 1 ]]; then
    show_help
    return 0
  fi

  local selected=1 key
  trap 'show_cursor; exit 130' INT TERM
  hide_cursor
  while true; do
    draw_menu "$selected"
    key="$(read_key)"
    case "$key" in
    "UP") ((selected > 1)) && selected=$((selected - 1)) ;;
    "DOWN") ((selected < 6)) && selected=$((selected + 1)) ;;
    "ENTER")
      show_cursor
      run_menu_selection "$selected"
      ;;
    "CHAR:"*)
      show_cursor
      run_menu_selection "${key#CHAR:}"
      ;;
    "VERSION")
      show_cursor
      clear_screen
      core --version
      exit 0
      ;;
    "HELP")
      show_cursor
      clear_screen
      show_help
      exit 0
      ;;
    "QUIT")
      show_cursor
      clear_screen
      exit 0
      ;;
    esac
    drain_pending_input
  done
}

case "${1:-}" in
"")
  interactive_menu
  ;;
"help" | "--help" | "-h")
  show_help
  ;;
"version" | "--version" | "-v" | "-V")
  core --version
  ;;
"update" | "list" | "doctor" | "config")
  core "$@"
  ;;
*)
  printf '%bUnknown command:%b %s\n' "$RED" "$NC" "$1" >&2
  printf "Use 'bloom --help' for usage information.\n" >&2
  exit 2
  ;;
esac
